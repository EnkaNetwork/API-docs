    "SkillInfoMap": {
        "chr_0032_lizhiyan_UltimateSkill": {
            "Icon": "skillicon/icon_ultimate_skill_lizhiyan_01",
            "Element": "Natural",
            "Name": "Gloompurge",
            "Desc": "Arcane akan memunculkan <@ba.key>Gloompurger Array</> yang akan langsung menimbulkan <@ba.natur>Nature DMG</> kepada musuh di dalam area efek (AOE).\nSaat musuh di dalam <@ba.key>Gloompurger Array</> terkena serangan Penuntas atau <#ba.lastcombo>Final Strike</> yang dilancarkan oleh operator terkontrol, <@ba.key>Gloompurger Array</> akan melepaskan <@ba.key>Cluster Strike</> yang akan menimbulkan Area DMG kepada musuh yang bersangkutan. Efek ini bisa diaktifkan maks 2 kali.\nSetelah mengaktifkan <@ba.key>Cluster Strike</> sebanyak 2 kali, ultimate akan beralih ke <@ba.key>Gloompurge Arcana</>.\n<@ba.key>Gloompurge Arcana</>: Menimbulkan <@ba.natur>Nature DMG</> kepada musuh di dalam AOE luas.",
            "ConditionData": {
                "lizhiyan_wisd": {
                    "Icon": "icon_ultimate_skill_lizhiyan_01",
                    "Name": "Array Arcana: INT",
                    "PostDesc": "<@ba.key>Array Arcana: INT</>:\n- Saat muncul, <@ba.key>Gloompurger Array</> juga mengakibatkan <#ba.corrupt>Corrosion</> kepada musuh di AOE secara paksa."
                },
                "lizhiyan_will": {
                    "Icon": "icon_ultimate_skill_lizhiyan_02",
                    "Name": "Array Arcana: WILL",
                    "PostDesc": "<@ba.key>Array Arcana: WILL</>:\n- Saat muncul, <@ba.key>Gloompurger Array</> juga mengincar musuh yang terkena <#ba.spellinflict>Arts Infliction</> di dalam AOE-nya, dan mengakibatkan satu tumpuk <#ba.spellinflict>Arts Infliction</> lagi dari elemen yang sama kepada mereka."
                }
            },

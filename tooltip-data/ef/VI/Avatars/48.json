        "chr_0032_lizhiyan_ComboSkill": {
            "Icon": "skillicon/icon_combo_skill_lizhiyan_01",
            "Element": "Natural",
            "Name": "Tư Thế Đặc Nhiệm IV",
            "Desc": "",
            "ConditionData": {
                "lizhiyan_wisd": {
                    "Icon": "icon_combo_skill_lizhiyan_01",
                    "Name": "Trận Huyền Thuật: TRÍ TUỆ",
                    "PostDesc": "KÍCH HOẠT LIÊN HOÀN: Khi <#ba.naturalinflict>Nhiễm Tự Nhiên</> hoặc ít nhất 2 cộng dồn <#ba.spellinflict>Nhiễm Thuật Pháp Phi Tự Nhiên</> được áp dụng lên kẻ địch.\nArcane lao tới mục tiêu và thiết lập 4 <@ba.key>Ảnh Chiến Thuật</>, áp dụng <#ba.naturalvul>Yếu Hóa Tự Nhiên</>, áp dụng <#ba.crystvul>Yếu Hóa Băng</> và <@ba.natur>ST Tự Nhiên</> lên mục tiêu cùng kẻ địch ở gần, đồng thời áp dụng <@ba.key>Giam Cầm</> lên mục tiêu đó. Khi <@ba.key>Giam Cầm</> kết thúc, các <@ba.key>Ảnh Chiến Thuật</> sẽ tấn công mục tiêu đó để gây ST Nổ.\n<@ba.key>Giam Cầm</>: Debuff làm chậm mọi hành động.\n<@ba.key>Trận Huyền Thuật: TRÍ TUỆ</>:\n- Dùng KN chiến đấu của Arcane đánh trúng kẻ địch đang chịu <@ba.key>Giam Cầm</> sẽ <#ba.return>hoàn trả</> một ít Điểm Kỹ Năng, kết thúc <@ba.key>Giam Cầm</> sớm, gây ST Nổ, áp dụng thêm một lần <#ba.naturalvul>Yếu Hóa Tự Nhiên</> và <#ba.crystvul>Yếu Hóa Băng</>, đồng thời sau một khoảng trễ ngắn sẽ gây nhiều lần ST cộng thêm.\n- Thời gian hồi KN liên hoàn được rút ngắn."
                },
                "lizhiyan_will": {
                    "Icon": "icon_combo_skill_lizhiyan_02",
                    "Name": "Trận Huyền Thuật: Ý CHÍ",
                    "PostDesc": "KÍCH HOẠT LIÊN HOÀN: Khi <#ba.spellinflict>Nhiễm Thuật Pháp</> được áp dụng lên kẻ địch.\nArcane lao tới mục tiêu và thiết lập 4 <@ba.key>Ảnh Chiến Thuật</>, gây <@ba.natur>ST Tự Nhiên</>, áp dụng thêm một cộng dồn <#ba.spellinflict>Nhiễm Thuật Pháp</> cùng nguyên tố, <#ba.naturalvul>Yếu Hóa Tự Nhiên</> và <#ba.crystvul>Yếu Hóa Băng</> lên mục tiêu cùng kẻ địch ở gần, đồng thời áp dụng <@ba.key>Giam Cầm</> lên mục tiêu đó. Khi <@ba.key>Giam Cầm</> kết thúc, các <@ba.key>Ảnh Chiến Thuật</> sẽ tấn công mục tiêu đó để gây ST Nổ.\n<@ba.key>Giam Cầm</>: Debuff làm chậm mọi hành động.\n<@ba.key>Trận Huyền Thuật: Ý CHÍ</>:\n- Áp dụng <@ba.key>Giam Cầm</> bằng cách thi triển KN liên hoàn cũng sẽ <@ba.key>kéo nhẹ</> các kẻ địch ở gần mục tiêu vào trong.\n- Thuộc tính Ý Chí có thể tăng thêm hiệu quả của <#ba.naturalvul>Yếu Hóa Tự Nhiên</> và <#ba.crystvul>Yếu Hóa Băng</> do KN liên hoàn áp dụng."
                }
            },

    "SkillInfoMap": {
        "chr_0032_lizhiyan_UltimateSkill": {
            "Icon": "skillicon/icon_ultimate_skill_lizhiyan_01",
            "Element": "Natural",
            "Name": "Trừ Ám",
            "Desc": "Arcane tạo ra <@ba.key>Trận Pháp Trừ Ám</>, lập tức gây <@ba.natur>ST Tự Nhiên</> cho kẻ địch trong phạm vi hiệu ứng (AOE).\nKhi cán viên đang điều khiển dùng Đòn Kết Liễu hoặc <@ba.key>Đòn Dứt Điểm</> đánh trúng kẻ địch trong <#ba.lastcombo>Trận Pháp Trừ Ám</>, <@ba.key>Trận Pháp Trừ Ám</> sẽ tung ra <@ba.key>Tập Kích Cụm</>, gây ST Diện Rộng lên kẻ địch đó. Hiệu ứng này kích hoạt tối đa 2 lần.\nSau khi kích hoạt <@ba.key>Tập Kích Cụm</> 2 lần, Tuyệt Kỹ sẽ chuyển thành <@ba.key>Bí Thuật Trừ Ám</>.\n<@ba.key>Bí Thuật Trừ Ám</>: Gây <@ba.natur>ST Tự Nhiên</> cho kẻ địch trong phạm vi hiệu ứng lớn.",
            "ConditionData": {
                "lizhiyan_wisd": {
                    "Icon": "icon_ultimate_skill_lizhiyan_01",
                    "Name": "Trận Huyền Thuật: TRÍ TUỆ",
                    "PostDesc": "<@ba.key>Trận Huyền Thuật: TRÍ TUỆ</>:\n- Khi được tạo ra, <@ba.key>Trận Pháp Trừ Ám</> cũng cưỡng chế áp dụng <#ba.corrupt>Ăn Mòn</> lên kẻ địch trong phạm vi hiệu ứng lớn."
                },
                "lizhiyan_will": {
                    "Icon": "icon_ultimate_skill_lizhiyan_02",
                    "Name": "Trận Huyền Thuật: Ý CHÍ",
                    "PostDesc": "<@ba.key>Trận Huyền Thuật: Ý CHÍ</>:\n- Khi được tạo ra, <@ba.key>Trận Pháp Trừ Ám</> cũng chọn làm mục tiêu các kẻ địch đang chịu <#ba.spellinflict>Nhiễm Thuật Pháp</> trong phạm vi hiệu ứng lớn của nó, đồng thời áp dụng thêm một cộng dồn <#ba.spellinflict>Nhiễm Thuật Pháp</> cùng nguyên tố lên chúng."
                }
            },

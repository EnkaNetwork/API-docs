    "SkillInfoMap": {
        "chr_0032_lizhiyan_UltimateSkill": {
            "Icon": "skillicon/icon_ultimate_skill_lizhiyan_01",
            "Element": "Natural",
            "Name": "Purificaoscurità",
            "Desc": "Arcana crea una <@ba.key>Schiera purificaoscurità</> che infligge immediatamente <@ba.natur>danni da natura</> ai nemici nel raggio d'azione.\nQuando colpisce un nemico entro la <@ba.key>Schiera purificaoscurità</> con una Mossa letale o un <#ba.lastcombo>Colpo finale</> eseguito dall'operatore controllato, la <@ba.key>Schiera purificaoscurità</> scatena un <@ba.key>Colpo a grappolo</> che infligge danni ad area a quel nemico. L'effetto può essere attivato per un massimo di 2 volte.\nDopo che il <@ba.key>colpo a grappolo</> è stato attivato 2 volte, l'abilità suprema viene sostituita con <@ba.key>Arcana purificaoscurità</>.\n<@ba.key>Arcana purificaoscurità</>: infligge <@ba.natur>danni da natura</> ai nemici entro un ampio raggio d'azione.",
            "ConditionData": {
                "lizhiyan_wisd": {
                    "Icon": "icon_ultimate_skill_lizhiyan_01",
                    "Name": "Schiera di Arcana: INT",
                    "PostDesc": "<@ba.key>Schiera di Arcana: INT</>:\n- Quando si crea, la <@ba.key>Schiera purificaoscurità</> applica anche <#ba.corrupt>Corrosione</> forzata ai nemici nel raggio d'azione."
                },
                "lizhiyan_will": {
                    "Icon": "icon_ultimate_skill_lizhiyan_02",
                    "Name": "Schiera di Arcana: VOL",
                    "PostDesc": "<@ba.key>Schiera di Arcana: VOL</>:\n- Quando si crea, la <@ba.key>Schiera purificaoscurità</> prende come bersaglio anche i nemici con <#ba.spellinflict>Afflizione da Arti</> nel raggio d'azione e applica loro un altro accumulo di <#ba.spellinflict>Afflizione da Arti</> dello stesso elemento."
                }
            },

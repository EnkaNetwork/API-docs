        "chr_0032_lizhiyan_UltimateSkill": {
            "Icon": "skillicon/icon_ultimate_skill_lizhiyan_01",
            "Element": "Natural",
            "Name": "破晦",
            "Desc": "生成<@ba.key>破晦阵</>，对区域内的敌人立即造成<@ba.natur>自然伤害</>。\n处于<@ba.key>破晦阵</>中的敌人被处决或受到主控干员<#ba.lastcombo>重击</>时，<@ba.key>破晦阵</>将对其发动<@ba.key>集束打击</>，造成范围伤害，最多发动2次。\n当发动2次<@ba.key>集束打击</>后，终结技切换为<@ba.key>破晦诀明</>。\n<@ba.key>破晦诀明</>：对前方大范围内敌人造成<@ba.natur>自然伤害</>。",
            "ConditionData": {
                "lizhiyan_wisd": {
                    "Icon": "icon_ultimate_skill_lizhiyan_01",
                    "Name": "阵诀·智",
                    "PostDesc": "<@ba.key>阵诀·智</>：\n- <@ba.key>破晦阵</>生成时，还会对区域内的敌人强制施加<#ba.corrupt>腐蚀</>。"
                },
                "lizhiyan_will": {
                    "Icon": "icon_ultimate_skill_lizhiyan_02",
                    "Name": "阵诀·意",
                    "PostDesc": "<@ba.key>阵诀·意</>：\n- <@ba.key>破晦阵</>生成时，还会对区域内处于<#ba.spellinflict>法术附着</>状态的敌人再次施加该<#ba.spellinflict>法术附着</>。"
                }
            },

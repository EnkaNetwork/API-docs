    "Talents": {
        "0": {
            "Title": "持続斬撃が敵に命中した時、カリンはパワーを1重獲得する（最大40重）。\n<color=#FFFFFF>『回避反撃』</color>、<color=#FFFFFF>『特殊スキル』</color>、<color=#FFFFFF>『強化特殊スキル』</color>、<color=#FFFFFF>『クイック支援』</color>、<color=#FFFFFF>『支援突撃』</color>において、\nチェーンソーを起爆させて敵に命中した時、すべてのパワーを消費して、\nパワー1重につき、カリンの攻撃力3%分のダメージを追加で与える。",
            "Description": "塵も積もれば",
            "Lore": "持続斬撃が敵に命中した時、カリンはパワーを1重獲得する（最大40重）。\n<color=#FFFFFF>『回避反撃』</color>、<color=#FFFFFF>『特殊スキル』</color>、<color=#FFFFFF>『強化特殊スキル』</color>、<color=#FFFFFF>『クイック支援』</color>、<color=#FFFFFF>『支援突撃』</color>において、チェーンソーを起爆させて敵に命中した時、すべてのパワーを消費して、パワー1重につき、カリンの攻撃力3%分のダメージを追加で与える。"
        },
        "2": {
            "Title": "<color=#FFFFFF>『通常攻撃』</color>、<color=#FFFFFF>『回避』</color>、<color=#FFFFFF>『支援スキル』</color>、<color=#FFFFFF>『特殊スキル』</color>、<color=#FFFFFF>『連携スキル』</color>のスキルレベル+2",
            "Description": "特殊勤務メイド",
            "Lore": "<color=#FFFFFF>『通常攻撃』</color>、<color=#FFFFFF>『回避』</color>、<color=#FFFFFF>『支援スキル』</color>、<color=#FFFFFF>『特殊スキル』</color>、<color=#FFFFFF>『連携スキル』</color>のスキルレベル+2"
        }
    },
    "CoreSkill": {
        "UniqueSkill": {
            "Title": "コアパッシブ：集中",
            "DescriptionByLevel": {
                "1": "連打または長押しで、カリンがチェーンソーで敵に持続的に斬撃を与えた時、スキルの与ダメージ+<color=#2BAD00>18.7%</color>。",
                "2": "連打または長押しで、カリンがチェーンソーで敵に持続的に斬撃を与えた時、スキルの与ダメージ+<color=#2BAD00>21.8%</color>。",
                "3": "連打または長押しで、カリンがチェーンソーで敵に持続的に斬撃を与えた時、スキルの与ダメージ+<color=#2BAD00>25%</color>。",
                "4": "連打または長押しで、カリンがチェーンソーで敵に持続的に斬撃を与えた時、スキルの与ダメージ+<color=#2BAD00>28.1%</color>。",
                "5": "連打または長押しで、カリンがチェーンソーで敵に持続的に斬撃を与えた時、スキルの与ダメージ+<color=#2BAD00>31.2%</color>。",
                "6": "連打または長押しで、カリンがチェーンソーで敵に持続的に斬撃を与えた時、スキルの与ダメージ+<color=#2BAD00>34.3%</color>。",
                "7": "連打または長押しで、カリンがチェーンソーで敵に持続的に斬撃を与えた時、スキルの与ダメージ+<color=#2BAD00>37.5%</color>。"
            }
        },
        "MathSkill": {
            "Title": "追加能力：お掃除ヘルパー",
            "Description": "チームに自身と同じ属性または同じ陣営のメンバーがいる時に発動：\nカリンの攻撃がブレイク状態の敵に命中した時、自身の与ダメージ+35%。"
        },
